# microCMS 移行スクリプト用の環境変数。`.env.migrate` にコピーして値を埋める。
# 実行: bun --env-file=.env.migrate scripts/migrate-microcms.ts --dry-run
# `.env.migrate` は .gitignore 済み（コミットしないこと）。

# --- 移行元（旧サービス）---
OLD_MICROCMS_SERVICE_DOMAIN=18ecz4av20
OLD_MICROCMS_API_KEY=          # GET 権限つき API キー

# --- 移行先（新サービス）---
NEW_MICROCMS_SERVICE_DOMAIN=   # 新しいサービスドメイン
NEW_MICROCMS_API_KEY=          # GET + PUT(POST) 権限つき Content API キー

# 画像をメディアライブラリへ再アップロードする場合のみ必要（任意）。
# 未設定なら画像は旧サービスの CDN URL を参照したまま移行される。
NEW_MICROCMS_MANAGEMENT_API_KEY=
